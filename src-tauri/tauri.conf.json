{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Piano Tracker",
  "version": "0.2.0",
  "identifier": "com.hugom.piano-tracker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Piano Tracker",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 550,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "target/release/WebView2Loader.dll": "WebView2Loader.dll"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
